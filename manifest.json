{
  "manifest_version": 3,
  "name": "Flickr AI Tagger Gemini",
  "version": "1.2.2",
  "description": "AI tag suggestions via Google Gemini \u2014 generates in background, popup can close",
  "permissions": [
    "activeTab",
    "scripting",
    "clipboardWrite",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://www.flickr.com/*",
    "https://live.staticflickr.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://nominatim.openstreetmap.org/*",
    "https://lens.google.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Flickr AI Tagger Gemini",
    "default_icon": {
      "128": "icon.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "scripts": [
      "background.js"
    ],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.flickr.com/photos/*/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "icons": {
    "128": "icon.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+F"
      },
      "description": "Open Flickr AI Tagger"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "strict_min_version": "128.0",
      "id": "flickr-ai-tagger-gemini@karel"
    }
  }
}